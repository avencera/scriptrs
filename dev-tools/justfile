fmt:
    cargo fmt --all

clippy:
    cargo clippy --all-targets -- -D warnings

check:
    just fmt
    just clippy

export-models output_dir="../fixtures/models":
    uv run python/export_models.py --output-dir {{output_dir}}

compare-coreml models_dir="../fixtures/models":
    uv run python/compare_coreml.py --models-dir {{models_dir}}

deploy-models models_dir="../fixtures/models" repo_id="avencera/scriptrs-models":
    uv run python/upload_models.py --models-dir {{models_dir}} --repo-id {{repo_id}}

compare-parakeet audio models_dir="../fixtures/models":
    cargo run --bin compare_parakeet_rs -- --audio {{audio}} --models-dir {{models_dir}}

compare-parakeet-dataset dataset="voxconverse" models_dir="../fixtures/models" max_files="3" chunks_per_file="2":
    cargo run --bin compare_parakeet_rs -- --speakrs-dataset {{dataset}} --models-dir {{models_dir}} --max-files {{max_files}} --chunks-per-file {{chunks_per_file}}
